model User {
    id           String  @id @default(uuid())
    name         String  @db.VarChar(255)
    email        String  @unique
    password     String
    phone        String?

    role   Role       @default(TENANT)
    status UserStatus @default(ACTIVE)

    // Relations
    properties     Property[]
    rentalRequests RentalRequest[]
    reviews        Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
