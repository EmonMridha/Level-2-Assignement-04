model User {
    id           String     @id @default(uuid())
    name         String     @db.VarChar(255)
    email        String     @unique
    password     String
    phone        String?
    profilePhoto String?
    role         Role       @default(TENANT)
    status       UserStatus @default(ACTIVE)
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
}

enum Role {
    TENANT
    LANDLORD
    ADMIN
}

enum UserStatus {
    ACTIVE
    BLOCKED
}
